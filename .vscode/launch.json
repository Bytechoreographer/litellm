{
  "version": "0.2.0",
  "configurations": [
    // ──────────────────────────────────────────────────────────────
    //  Backend — Dev
    //  对应 pep-cd/llm-api-gateway/dev.yaml
    //  数据库：litellm_dev，版本动态从 pep-cd/llm-api-gateway/dev.yaml 读取
    // ──────────────────────────────────────────────────────────────
    {
